# CONFIGURAÇÃO DE PROXY PARA NODE.JS - REI DOS BOTS

RewriteEngine On

# 1. Redirecionar todas as chamadas para /api para o servidor Node na porta 3000
RewriteRule ^api/(.*) http://localhost:3000/api/$1 [P,L]

# 2. Configuração de Suporte a WebSockets (WSS)
# Se o Hostoo suportar proxy de WebSocket via mod_proxy_wstunnel
RewriteCond %{HTTP:Upgrade} websocket [NC]
RewriteCond %{HTTP:Connection} upgrade [NC]
RewriteRule ^(.*) ws://localhost:3000/$1 [P,L]

# 3. Cache e Performance (Opcional)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
</IfModule>
