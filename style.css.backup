    gap: 5px;
}

.spec-label {
    font-size: 14px;
    color: var(--text-gray);
    text-transform: uppercase;
}

.spec-value {
    font-size: 16px;
    color: var(--text-light);
    font-weight: bold;
}

/* Scrollbar personalizada para o modal */
.modal-content::-webkit-scrollbar {
    width: 10px;
}

.modal-content::-webkit-scrollbar-track {
    background: #1a1a1a;
}

.modal-content::-webkit-scrollbar-thumb {
    background: var(--primary-color);
    border-radius: 5px;
}

.modal-content::-webkit-scrollbar-thumb:hover {
    background: #ff0000;
}

/* Modal Styles */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
}

.modal.active {
    display: flex;
}

.modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(5px);
}

.modal-content {
    position: relative;
    width: 95%;
    height: 95%;
    background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
    border: 1px solid rgba(255, 215, 0, 0.2);
    z-index: 10000;
}

.modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 50px;
    height: 50px;
    background: rgba(255, 0, 0, 0.2);
    border: 2px solid rgba(255, 0, 0, 0.5);
    border-radius: 50%;
    color: #fff;
    font-size: 30px;
    cursor: pointer;
    z-index: 10001;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.modal-close:hover {
    background: rgba(255, 0, 0, 0.4);
    border-color: rgba(255, 0, 0, 0.8);
    transform: rotate(90deg);
}

.modal-body {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    padding: 40px;
}

.modal-video-container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto 30px;
    border-radius: 15px;
    overflow: hidden;
    border: 2px solid rgba(255, 215, 0, 0.3);
}

.modal-video {
    width: 100%;
    height: auto;
    display: block;
}

.modal-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 20px;
    color: #ffd700;
    text-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
}

.modal-description {
    text-align: center;
    font-size: 1.1rem;
    line-height: 1.8;
    color: #ccc;
    max-width: 900px;
    margin: 0 auto 40px;
}

.features-section {
    margin-bottom: 50px;
}

.features-section-title {
    font-size: 1.8rem;
    color: #ffd700;
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 2px solid rgba(255, 215, 0, 0.3);
}

.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.feature-card {
    background: linear-gradient(135deg, rgba(255, 215, 0, 0.05) 0%, rgba(255, 215, 0, 0.02) 100%);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 12px;
    padding: 20px;
    transition: all 0.3s ease;
}

.feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(255, 215, 0, 0.2);
    border-color: rgba(255, 215, 0, 0.5);
}

.feature-card-title {
    font-size: 1.1rem;
    font-weight: bold;
    color: #ffd700;
    margin-bottom: 10px;
}

.feature-card-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #aaa;
}

.bot-specs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
    margin-top: 40px;
    padding: 30px;
    background: rgba(255, 215, 0, 0.05);
    border-radius: 15px;
    border: 1px solid rgba(255, 215, 0, 0.2);
}

.spec-item {
    display: flex;
    align-items: center;
    gap: 10px;
}

.spec-label {
    font-weight: bold;
    color: #ffd700;
}

.spec-value {
    color: #fff;
}

/* Scrollbar do Modal */
.modal-body::-webkit-scrollbar {
    width: 12px;
}

.modal-body::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.3);
    border-radius: 10px;
}

.modal-body::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, #ffd700 0%, #ffed4e 100%);
    border-radius: 10px;
}

.modal-body::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, #ffed4e 0%, #ffd700 100%);
}

/* Footer */
.footer {
    background: linear-gradient(135deg, #1a1f2e 0%, #0f1419 100%);
    padding: 30px 0 15px;
    border-top: 1px solid rgba(255, 215, 0, 0.1);
}

.footer-content {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 40px;
    align-items: center;
    margin-bottom: 20px;
}

/* Footer Brand */
.footer-brand {
    display: flex;
    align-items: center;
}

.footer-logo {
    display: flex;
    align-items: center;
    gap: 12px;
}

.footer-logo-img {
    width: 35px;
    height: 35px;
    border-radius: 8px;
}

.footer-logo h1 {
    font-size: 1.3rem;
    font-weight: bold;
    color: #fff;
    margin: 0;
}

.footer-logo h1 span {
    color: #ff4444;
}

/* Footer Seals */
.footer-seals {
    display: flex;
    gap: 15px;
    align-items: center;
    justify-content: center;
}

.seal-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    transition: all 0.3s ease;
}

.seal-badge:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 215, 0, 0.3);
    transform: translateY(-2px);
}

.seal-badge-icon {
    font-size: 1.5rem;
    line-height: 1;
}

.seal-18 {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #dc2626, #ff4444);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: bold;
    color: #fff;
    border: 2px solid #fff;
}

.seal-badge-text {
    font-size: 0.7rem;
    color: #9ca3af;
    line-height: 1.2;
    text-align: left;
}

.seal-badge-text strong {
    color: #fff;
    display: block;
    font-size: 0.75rem;
}

/* Footer Social */
.footer-social {
    display: flex;
    gap: 12px;
    align-items: center;
}

.social-link {
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #9ca3af;
    transition: all 0.3s ease;
}

.social-link:hover {
    background: rgba(255, 215, 0, 0.1);
    border-color: rgba(255, 215, 0, 0.3);
    color: #ffd700;
    transform: translateY(-2px);
}

/* Footer Warning */
.footer-warning-container {
    padding: 20px 0;
    margin-top: 30px;
}

.footer-warning {
    color: #fbbf24;
    font-size: 0.9rem;
    padding: 15px 25px;
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
    border-radius: 8px;
    line-height: 1.6;
    max-width: 900px;
    margin: 0 auto;
    font-weight: 500;
}

/* Footer Bottom */
.footer-bottom {
    padding-top: 15px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    text-align: center;
}

.footer-copyright {
    color: #6b7280;
    font-size: 0.8rem;
    margin-bottom: 5px;
}

.footer-disclaimer {
    color: #4b5563;
    font-size: 0.7rem;
    line-height: 1.4;
}

/* Responsive */
@media (max-width: 1024px) {
    .footer-content {
        grid-template-columns: 1fr;
        gap: 25px;
        text-align: center;
    }

    .footer-brand {
        justify-content: center;
    }

    .footer-seals {
        justify-content: center;
        flex-wrap: wrap;
    }

    .footer-social {
        justify-content: center;
    }
}

@media (max-width: 768px) {
    .seal-badge {
        flex-direction: column;
        text-align: center;
        padding: 10px 12px;
    }

    .seal-badge-text {
        text-align: center;
    }
}

/* Warning Section */
.warning-section {
    background: var(--dark-bg);
    padding: 30px 0;
}

.warning-box {
    max-width: 1000px;
    margin: 0 auto;
}

.warning-text {
    color: #fbbf24;
    font-size: 1rem;
    padding: 20px 30px;
    background: rgba(251, 191, 36, 0.1);
    border: 2px solid rgba(251, 191, 36, 0.4);
    border-radius: 12px;
    line-height: 1.7;
    text-align: center;
    font-weight: 500;
    box-shadow: 0 4px 15px rgba(251, 191, 36, 0.1);
}
