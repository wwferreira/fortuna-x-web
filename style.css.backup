    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.feature-card {
    background: linear-gradient(135deg, rgba(220, 38, 38, 0.1), rgba(147, 51, 234, 0.1));
    padding: 25px;
    border-radius: 15px;
    border: 2px solid rgba(220, 38, 38, 0.3);
    transition: all 0.3s;
    cursor: pointer;
}

.feature-card:hover {
    transform: translateY(-5px);
    border-color: var(--primary-color);
    box-shadow: 0 10px 30px rgba(220, 38, 38, 0.4);
}

.feature-card-icon {
    font-size: 36px;
    margin-bottom: 15px;
    text-align: center;
}

.feature-card-title {
    font-size: 18px;
    color: var(--text-light);
    margin-bottom: 10px;
    font-weight: bold;
    text-align: center;
}

.feature-card-desc {
    font-size: 14px;
    color: var(--text-gray);
    line-height: 1.5;
    text-align: center;
}

.features-section {
    margin-bottom: 40px;
}

.features-section-title {
    font-size: 28px;
    color: var(--primary-color);
    margin-bottom: 25px;
    padding-bottom: 10px;
    border-bottom: 2px solid rgba(220, 38, 38, 0.3);
    text-align: center;
}

.bot-specs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    padding: 30px;
    background: rgba(220, 38, 38, 0.1);
    border-radius: 15px;
